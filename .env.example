# Copy this file to .env.local (git-ignored) and fill in real values.
# These are your Supabase project's PUBLIC anon key + URL, used by the
# browser app. They are safe to expose to the client ONLY because Row
# Level Security (RLS) policies restrict what that key can actually do
# server-side -- see src/services/db.ts SQL_SCHEMA. Do not disable RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Used server-side only by api/doc.js (Vercel serverless function) to
# render social-preview metadata for shared document links. Set these
# in the Vercel Project Settings -> Environment Variables, not in a
# committed file.
SUPABASE_URL=
SUPABASE_ANON_KEY=
